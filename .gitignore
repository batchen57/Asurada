# ==========================================
# Asurada Root .gitignore
# ==========================================

# 1. Dependency Directories
node_modules/
jspm_packages/
backend/venv/
backend/.venv/
venv/
.venv/
env/
ENV/

# 2. Build & Distribution Outputs
dist/
dist-ssr/
build/
out/
frontend/dist/

# 3. Python Compilation Cache
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/

# 4. Databases & SQLite
*.db
*.sqlite
backend/asurada.db
backend/asurada.db-journal

# 5. Application Runtime & Simulation Data
**/app/data/
*.local

# 6. Logs
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# 7. IDE, Editor & OS Configuration
.vscode/
!.vscode/extensions.json
.idea/
.DS_Store
Thumbs.db
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
